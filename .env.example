# Example environment for ShanCi Expense.
# Copy to .env.production (or .env.local) and fill in real values.

# Shared
VITE_API_TIMEOUT=10000

# --- v1 (current production app) endpoints ---
VITE_GET_WEEKLY_EXPENSE_URL=
VITE_ADD_WEEKLY_EXPENSE_URL=
VITE_GET_MONTHLY_EXPENSE_URL=
VITE_ADD_MONTHLY_EXPENSE_URL=
VITE_GET_RECAP_URL=

# --- v2 "Amplop" backend (expense-functions, single routed Cloud Function) ---
# Base URL of the backend. Defaults to http://localhost:8080 (local dev server)
# when unset. Point at the deployed function for production.
#   GET    {base}/month?year=&month=  -> render-ready month dashboard
#   POST   {base}/expenses            -> create expense
#   PUT    {base}/expenses/{id}       -> update expense
#   DELETE {base}/expenses/{id}       -> delete (204)
# (subscription & budget endpoints exist server-side; wired in a later phase.)
VITE_API_BASE_URL=http://localhost:8080
