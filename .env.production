# Production environment variables.
#
# These are all PUBLIC Cloud Run endpoints (no credentials) — safe to commit,
# per CLAUDE.md ("API URLs are public Cloud Run endpoints; never add
# credentials"). `vite build` runs in production mode and loads this file, so
# the CI deploy (npm run build -> Firebase Hosting) bakes these into the bundle.

VITE_API_TIMEOUT=10000

# --- v2 "Amplop" backend (the production app: root index.html) ---
# Single routed Cloud Run service that owns all envelope/budget math and the
# expense / budget / subscription REST endpoints.
VITE_API_BASE_URL=https://expense-126234090787.asia-southeast1.run.app

# --- v1 legacy app endpoints (preserved at /legacy.html) ---
VITE_GET_WEEKLY_EXPENSE_URL=https://weekly-expense-get-126234090787.asia-southeast1.run.app
VITE_ADD_WEEKLY_EXPENSE_URL=https://weekly-expense-add-126234090787.asia-southeast1.run.app
VITE_GET_MONTHLY_EXPENSE_URL=https://monthly-expense-get-126234090787.asia-southeast1.run.app
VITE_ADD_MONTHLY_EXPENSE_URL=https://monthly-expense-add-126234090787.asia-southeast1.run.app
VITE_GET_RECAP_URL=https://recap-get-126234090787.asia-southeast1.run.app
